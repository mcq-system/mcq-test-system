<div class="q-card">
  <div class="q-check"></div>
  <div class="q-body">
    <div class="q-top">
      <span class="q-id">{{id}}</span>
      <span class="q-type-badge {{typeBadgeClass type}}">{{typeLabel type}}</span>
      <span class="q-level">{{level}}</span>
      <span class="q-level q-topic">{{topic}}</span>
    </div>
    <div class="q-text">{{text}}</div>
    <div class="q-meta">
      <span>{{opts}} đáp án</span>
      <span>·</span>
      <span>Dùng {{used}} lần</span>
    </div>
  </div>
  <div class="q-actions">
    <button class="icon-btn" title="Xem">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z"/>
        <circle cx="8" cy="8" r="2"/>
      </svg>
    </button>
    <button class="icon-btn" title="Sửa">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M11 2.5l2.5 2.5L5 13H2.5v-2.5L11 2.5z"/>
      </svg>
    </button>
    <button class="icon-btn icon-btn--danger" title="Xóa" data-id="{{id}}">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 4h10M6 4V3h4v1M5 4l1 9h4l1-9"/>
      </svg>
    </button>
  </div>
</div>
