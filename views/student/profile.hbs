<div class="container-profile">
    <!--Thông tin tổng quát -->
    <aside class="card profile-sidebar">
        <div class="avatar-wrapper">
            <div class="avatar-circle">{{slice user.first_name 0 1}}</div>
            <button class="btn-edit-avatar" title="Đổi ảnh đại diện">📷</button>
        </div>
        <h2>{{user.last_name}} {{user.first_name}}</h2>
        <p style="color: #65676b; text-transform: capitalize;">{{user.role}}</p>

        <div class="info-list">
            <div class="info-item">📧 {{user.email}}</div>
            <div class="info-item">📞 {{user.phone}}</div>
            <div class="info-item">📍 {{user.address}}</div>
            <div class="info-item">📅 {{user.dob_display}}</div>
        </div>

        <div
            style="text-align: left; margin-top: 20px; font-size: 14px; border-top: 1px solid #eee; padding-top: 15px;">
            <p><strong>Mã định danh:</strong> <span style="float: right;">{{user.student_id}}</span></p>
            <p><strong>Lớp/Đơn vị:</strong> <span style="float: right;">{{user.class_name}}</span></p>
        </div>
    </aside>

    <!-- Form cập nhật -->
    <main class="card profile-main">
        <h3>Cập nhật thông tin</h3>
        <p style="color: #65676b; font-size: 14px; margin-bottom: 20px;">Quản lý thông tin cá nhân và bảo mật tài khoản
        </p>

        <!-- Tab header -->
        <div class="tab-header">
            <div class="tab-item active" id="tab-info">Thông tin cá nhân</div>
            <div class="tab-item" id="tab-password">Đổi mật khẩu</div>
        </div>

        <!-- ── Panel 1: Thông tin cá nhân ── -->
        <div class="tab-panel active" id="panel-info">
            <form action="/student/update-profile" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Họ và tên</label>
                        <input type="text" name="fullname" value="{{user.last_name}} {{user.first_name}}" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" value="{{user.email}}" required>
                    </div>
                    <div class="form-group">
                        <label>Số điện thoại</label>
                        <input type="text" name="phone" value="{{user.phone}}">
                    </div>
                    <div class="form-group">
                        <label>Ngày sinh</label>
                        <input type="date" name="dob" value="{{user.dob_formatted}}">
                    </div>
                    <div class="form-group full-width">
                        <label>Địa chỉ</label>
                        <input type="text" name="address" value="{{user.address}}">
                    </div>
                </div>
                <button type="submit" class="btn-save" style="margin-top: 20px;">💾 Lưu thay đổi</button>
            </form>
        </div>

        <!-- ── Panel 2: Đổi mật khẩu ── -->
        <div class="tab-panel" id="panel-password">
            <!-- Thông báo kết quả -->
            <div id="cp-message" class="cp-message" style="display:none;"></div>

            <form id="change-password-form" novalidate>
                <div class="form-group">
                    <label for="current-password">Mật khẩu hiện tại</label>
                    <div class="input-password-wrapper">

                        <input type="password" id="current-password" placeholder="Nhập mật khẩu hiện tại"
                            autocomplete="current-password">
                        <button type="button" class="toggle-password" data-target="current-password">👁️</button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="new-password">Mật khẩu mới</label>
                    <div class="input-password-wrapper">

                        <input type="password" id="new-password" placeholder="Nhập mật khẩu mới"
                            autocomplete="new-password">
                        <button type="button" class="toggle-password" data-target="new-password">👁️</button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="confirm-password">Xác nhận mật khẩu mới</label>
                    <div class="input-password-wrapper">

                        <input type="password" id="confirm-password" placeholder="Nhập lại mật khẩu mới"
                            autocomplete="new-password">
                        <button type="button" class="toggle-password" data-target="confirm-password">👁️</button>
                    </div>
                </div>

                <button type="submit" class="btn-save" style="margin-top: 20px;">Đổi mật khẩu</button>
            </form>
        </div>
    </main>
</div>

<script src="/javascripts/profile.js"></script>