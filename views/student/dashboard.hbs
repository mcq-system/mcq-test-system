<div class="stats-row">
    <div class="card stat-card d-flex flex-row">
        <div class="stat-icon icon-blue">
            <i class="fas fa-graduation-cap"></i>
        </div>
        <div>
            <div class="stat-label">Lớp đang học</div>
            <div class="stat-value">{{stats.classCount}}</div>
        </div>
    </div>
    <div class="card stat-card d-flex flex-row">
        <div class="stat-icon icon-cyan">
            <i class="fas fa-file-alt"></i>
        </div>
        <div>
            <div class="stat-label">Bài thi đã làm</div>
            <div class="stat-value">{{stats.examCount}}</div>
        </div>
    </div>
    <div class="card stat-card d-flex flex-row">
        <div class="stat-icon icon-blue-light">
            <i class="fas fa-chart-line"></i>
        </div>
        <div>
            <div class="stat-label">Điểm trung bình</div>
            <div class="stat-value">{{stats.avgScore}}</div>
        </div>
    </div>
</div>

<div class="main-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title">Lớp học của tôi</div>
                <div class="card-subtitle">Các lớp đang tham gia</div>
            </div>
            <a href="/student/my-classes" class="view-all">Xem tất cả <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="course-list">
            {{#each classes}}
            <div class="course-item">
                <div class="course-header">
                    <div>
                        <div class="course-name">{{name}}</div>
                        <div class="course-teacher">GV: {{teacherName}}</div>
                    </div>
                    <div class="course-schedule"><i class="far fa-calendar-alt"></i> {{scheduleStr}}</div>
                </div>
                <div class="progress-section">
                    <span class="progress-label">Tiến độ</span>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 0%;"></div>
                    </div>
                    <span class="progress-percent">0%</span>
                </div>
            </div>
            {{else}}
            <p style="text-align: center; padding: 20px; color: #888;">Bạn chưa tham gia lớp học nào.</p>
            {{/each}}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title">Kỳ thi sắp tới</div>
                <div class="card-subtitle">Dựa trên lịch của giảng viên</div>
            </div>
            <a href="/student/exam-do" class="view-all">Xem tất cả <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="exam-list">
            {{#each exams}}
            <div class="exam-item">
                <div class="exam-info">
                    <div>
                        <div class="exam-title">{{title}}</div>
                        <div class="exam-subject">{{#if class_id}}{{class_id.name}}{{else}}Tiếng Anh{{/if}}</div>
                    </div>
                    <span class="tag tag-reading">English</span>
                </div>
                <div class="exam-meta">
                    <span><i class="far fa-calendar"></i> {{formatDate start_time}}</span>
                    <span><i class="far fa-clock"></i> {{duration_minutes}} phút</span>
                    <span><i class="far fa-file-alt"></i> {{questionCount}} câu</span>
                </div>
                <form action="/student/exam-sessions/start" method="POST">
                    <input type="hidden" name="exam_id" value="{{_id}}">
                    <button type="submit" class="btn-enter-exam">Vào phòng thi</button>
                </form>
            </div>
            {{else}}
            <p style="text-align: center; padding: 20px; color: #888;">Hiện tại không có kỳ thi nào.</p>
            {{/each}}
        </div>
    </div>
</div>

