<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kiểm tra giữa kỳ - Lập trình C++</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    :root{
      --bg:#f6f9fe;
      --card:#ffffff;
      --line:#d7e0ea;
      --text:#111827;
      --muted:#6b7280;
      --blue:#0b5cab;
      --blue-soft:#eaf2ff;
      --shadow:0 1px 2px rgba(16,24,40,.04), 0 8px 24px rgba(16,24,40,.04);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .topbar {
      height: 84px;
      background: rgba(255,255,255,.88);
      border-bottom: 1px solid #e5ebf2;
      backdrop-filter: blur(8px);
      padding: 0 18px;
    }

    .top-title {
      font-size: 18px;
      font-weight: 700;
      margin: 0;
      line-height: 1.2;
    }

    .top-subtitle {
      margin-top: 4px;
      font-size: 14px;
      color: #586579;
    }

    .timer-box {
      min-width: 106px;
      height: 48px;
      padding: 0 16px;
      border-radius: 12px;
      background: #e7eff8;
      color: var(--blue);
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 18px;
    }

    .submit-btn {
      height: 48px;
      min-width: 124px;
      padding: 0 18px;
      border: 0;
      border-radius: 12px;
      background: var(--blue);
      color: #fff;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 6px 14px rgba(11,92,171,.18);
    }

    .page-wrap {
      padding: 14px 18px 20px;
    }

    .sidebar-card,
    .main-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .sidebar-card {
      padding: 22px 22px 18px;
    }

    .main-card {
      padding: 22px 24px 18px;
      min-height: 640px;
    }

    .sidebar-title {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 18px;
    }

    .side-progress {
      height: 10px;
      border-radius: 999px;
      background: #e8eef5;
      overflow: hidden;
      margin-bottom: 34px;
    }

    .side-progress .bar {
      height: 100%;
      width: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #c8d8eb, #b8cbe2);
    }

    .q-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      margin-bottom: 22px;
    }

    .q-btn {
      height: 50px;
      border-radius: 10px;
      border: 1px solid #e1e8f0;
      background: #f3f7fb;
      color: #6b7280;
      font-weight: 700;
      font-size: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: .15s ease;
    }

    .q-btn.active {
      background: #fff;
      color: var(--blue);
      border: 2px solid var(--blue);
      box-shadow: 0 0 0 3px rgba(11,92,171,.08);
    }

    .q-btn.done {
      background: #e9f8ef;
      border-color: #d0f0dc;
      color: #15803d;
    }

    .q-btn.marked {
      background: #fff7e0;
      border-color: #f7df9b;
      color: #b7791f;
    }

    .side-divider {
      height: 1px;
      background: #dfe7ef;
      margin: 10px 0 14px;
    }

    .legend {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 14px;
      color: #566173;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      white-space: nowrap;
    }

    .legend-dot {
      width: 14px;
      height: 14px;
      border-radius: 4px;
      display: inline-block;
    }

    .legend-dot.done { background: #14963d; }
    .legend-dot.todo { background: #edf2f7; border: 1px solid #dfe7ef; }
    .legend-dot.marked { background: #d6a100; }

    .pill {
      display: inline-flex;
      align-items: center;
      height: 34px;
      padding: 0 12px;
      border-radius: 8px;
      border: 1px solid #d7e0ea;
      background: #fff;
      color: #111827;
      font-weight: 600;
      font-size: 15px;
    }

    .mark-btn {
      height: 34px;
      padding: 0 14px;
      border-radius: 8px;
      border: 1px solid #d7e0ea;
      background: #fff;
      font-weight: 600;
      color: #111827;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .question-text {
      margin: 34px 0 28px;
      font-size: 22px;
      line-height: 1.55;
      color: #111827;
      max-width: 920px;
      white-space: pre-line;
    }

    .option-card {
      border: 1.5px solid #d7e0ea;
      border-radius: 12px;
      background: #fff;
      padding: 18px 18px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: .15s ease;
    }

    .option-card:hover {
      border-color: #bcd0e4;
      box-shadow: 0 6px 16px rgba(16,24,40,.04);
    }

    .option-radio {
      width: 18px;
      height: 18px;
      border: 1.8px solid #cfd9e4;
      border-radius: 50%;
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      background: #fff;
    }

    .option-letter {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: #eff4fb;
      color: #111827;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
    }

    .option-label {
      font-size: 18px;
      font-weight: 700;
      color: #111827;
    }

    .option-text {
      font-size: 18px;
      color: #111827;
      font-weight: 500;
    }

    .bottom-bar {
      border-top: 1px solid #e4ebf2;
      padding-top: 18px;
      margin-top: 12px;
    }

    .nav-btn {
      height: 44px;
      min-width: 130px;
      border-radius: 8px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .nav-btn.prev {
      background: #fff;
      border: 1px solid #e1e7ef;
      color: #8a94a3;
    }

    .nav-btn.next {
      background: var(--blue);
      border: 1px solid var(--blue);
      color: #fff;
    }

    .page-indicator {
      color: #506079;
      font-size: 18px;
      font-weight: 500;
      min-width: 90px;
      text-align: center;
    }

    .header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    @media (max-width: 991.98px) {
      .topbar {
        height: auto;
        padding: 14px 16px;
      }

      .header-row {
        flex-direction: column;
      }

      .sidebar-card,
      .main-card {
        border-radius: 14px;
      }

      .question-text {
        font-size: 18px;
      }

      .option-label,
      .option-text {
        font-size: 16px;
      }
    }
  </style>
</head>

<body>
  <div class="topbar d-flex align-items-center justify-content-between">
    <div>
      <h1 class="top-title">Kiểm tra giữa kỳ - Lập trình C++</h1>
      <div class="top-subtitle">Đã trả lời: 0/5 câu</div>
    </div>

    <div class="header-actions">
      <div class="timer-box">
        <i class="bi bi-clock"></i>
        <span>{{timeLeft}}</span>
      </div>

      <button class="submit-btn">
        <i class="bi bi-send"></i>
        <span>Nộp bài</span>
      </button>
    </div>
  </div>

  <div class="page-wrap">
    <div class="container-fluid">
      <div class="row g-4 justify-content-center">
        <div class="col-12 col-lg-3 col-xl-3">
          <div class="sidebar-card">
            <div class="sidebar-title">Danh sách câu hỏi</div>

            <div class="side-progress">
              <div class="bar"></div>
            </div>

            <div class="q-grid">
              {{#each questions}}
                <button
                  type="button"
                  class="q-btn {{#if this.active}}active{{/if}} {{#if this.done}}done{{/if}} {{#if this.marked}}marked{{/if}}"
                >
                  {{this.number}}
                </button>
              {{/each}}
            </div>

            <div class="side-divider"></div>

            <div class="legend">
              <div class="legend-item"><span class="legend-dot done"></span> Đã làm</div>
              <div class="legend-item"><span class="legend-dot todo"></span> Chưa làm</div>
              <div class="legend-item"><span class="legend-dot marked"></span> Đánh dấu</div>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-9 col-xl-8">
          <div class="main-card">
            <div class="d-flex align-items-start justify-content-between">
              <span class="pill">Câu {{currentQuestion.number}}/{{totalQuestions}}</span>
              <button class="mark-btn">
                <i class="bi bi-flag"></i>
                <span>Đánh dấu</span>
              </button>
            </div>

            <div class="question-text">{{currentQuestion.text}}</div>

            <form>
              {{#each currentQuestion.options}}
                <label class="option-card">
                  <span class="option-radio">
                    <input
                      type="radio"
                      name="answer"
                      id="option{{@index}}"
                      class="form-check-input m-0"
                      style="opacity:0; position:absolute;"
                    >
                  </span>

                  <span class="option-letter">{{this.label}}</span>
                  <span class="option-text">{{this.text}}</span>
                </label>
              {{/each}}
            </form>

            <div class="bottom-bar">
              <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <button class="btn nav-btn prev">
                  <i class="bi bi-chevron-left"></i>
                  <span>Câu trước</span>
                </button>

                <div class="page-indicator">{{currentQuestion.number}} / {{totalQuestions}}</div>

                <button class="btn nav-btn next">
                  <span>Câu sau</span>
                  <i class="bi bi-chevron-right"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>