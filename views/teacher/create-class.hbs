{{#> layout-teacher}}
<div class="main-content">
  <div class="top-bar"><h2>Tạo lớp mới</h2><a href="/teacher/classes" class="btn btn-secondary">↩ Quay lại</a></div>
  <div class="card">
    <form action="/teacher/classes" method="POST">
      <div class="form-grid">
        <div class="form-group full"><label>Tên lớp *</label><input type="text" name="class_name" required></div>
        <div class="form-group"><label>Mã lớp *</label><input type="text" name="class_code" required></div>
        <div class="form-group"><label>Topic</label><input type="text" name="topic"></div>
        <div class="form-group"><label>Số HV tối đa</label><input type="number" name="max_students" value="30"></div>
        <div class="form-group"><label>Ngày bắt đầu</label><input type="date" name="start_date"></div>
        <div class="form-group"><label>Ngày kết thúc</label><input type="date" name="end_date"></div>
        <div class="form-group full"><label>Mô tả</label><textarea name="description" rows="3"></textarea></div>
      </div>
      <button type="submit" class="btn btn-primary">💾 Tạo lớp</button>
    </form>
  </div>
</div>
{{/layout-teacher}}