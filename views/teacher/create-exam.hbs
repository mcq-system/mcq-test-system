{{#> layout-teacher}}
<div class="main-content">
  <div class="top-bar"><h2>Tạo đề thi</h2><a href="/teacher/exams" class="btn btn-secondary">↩ Quay lại</a></div>
  <div class="card">
    <form id="examForm" action="/teacher/exams" method="POST">
      <div class="form-grid">
        <div class="form-group full"><label>Tên đề *</label><input type="text" name="exam_name" required></div>
        <div class="form-group"><label>Lớp</label>
          <select name="class_id">
            <option value="">-- Chọn lớp --</option>
            {{#each classes}}<option value="{{_id}}">{{class_name}}</option>{{/each}}
          </select>
        </div>
        <div class="form-group"><label>Thời gian (phút)</label><input type="number" name="duration" value="45"></div>
      </div>
      <div class="builder-grid">
        <div class="card">
          <div class="card-title">📦 Ngân hàng câu hỏi</div>
          <div id="bank" style="max-height:300px;overflow-y:auto">
            {{#each questions}}
            <div class="question-item" draggable="true" data-id="{{_id}}">
              <div>{{content}}</div><span style="color:#999">⠿</span>
            </div>{{/each}}
          </div>
        </div>
        <div class="card">
          <div class="card-title">📋 Đề thi</div>
          <div id="drop" class="drop-zone">Kéo câu hỏi vào đây</div>
          <input type="hidden" name="questions" id="q-json" value="[]">
        </div>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:20px">💾 Lưu đề</button>
    </form>
  </div>
</div>
<script>
let selected=[];
document.querySelectorAll('#bank .question-item').forEach(el=>{
  el.addEventListener('dragstart',e=>e.dataTransfer.setData('text',el.dataset.id));
  el.addEventListener('click',()=>addToExam(el.dataset.id,el));
});
const drop=document.getElementById('drop');
drop.addEventListener('dragover',e=>{e.preventDefault();drop.classList.add('dragover')});
drop.addEventListener('dragleave',()=>drop.classList.remove('dragover'));
drop.addEventListener('drop',e=>{e.preventDefault();drop.classList.remove('dragover');
  const id=e.dataTransfer.getData('text');const src=document.querySelector(`[data-id="${id}"]`);
  if(src&&!selected.includes(id))addToExam(id,src);});
function addToExam(id,src){if(selected.includes(id))return;selected.push(id);
  const clone=src.cloneNode(true);clone.onclick=()=>{selected=selected.filter(x=>x!==id);clone.remove();upd();};
  clone.querySelector('span').textContent='✖';drop.classList.add('has-items');
  drop.innerHTML='';drop.appendChild(clone);upd();}
function upd(){document.getElementById('q-json').value=JSON.stringify(selected);}
document.getElementById('examForm').onsubmit=e=>{if(!selected.length){e.preventDefault();alert('Chọn ít nhất 1 câu hỏi!');}};
</script>
{{/layout-teacher}}