{{!-- views/teacher/create-exam.hbs — Tạo đề thi --}}

<!-- Header -->
<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/teacher/exams" class="btn btn-link text-muted p-0 text-decoration-none">
    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
  </a>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-6">
    <label class="form-label small fw-semibold">Tên đề thi</label>
    <input type="text" class="form-control" id="exam-name" placeholder="VD: TOEIC Practice Test 1">
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold">Thời gian (phút)</label>
    <div class="input-group">
      <span class="input-group-text"><i class="fas fa-clock text-muted"></i></span>
      <input type="number" class="form-control" id="exam-duration" value="60">
    </div>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold">Topic</label>
    <select class="form-select" id="exam-topic">
      <option value="">Chọn topic</option>
      <option>TOEIC</option><option>IELTS</option><option>Grammar</option><option>Vocabulary</option>
    </select>
  </div>
</div>

<!-- Split panel -->
<div class="row g-3">
  <!-- LEFT: Question bank -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-bottom py-3">
        <h6 class="fw-bold mb-1">Ngân hàng câu hỏi</h6>
        <small class="text-muted">Kéo thả hoặc click để thêm vào đề thi</small>
      </div>
      <div class="card-body pt-2 pb-2">
        <div class="d-flex gap-2 mb-2">
          <input type="text" class="form-control form-control-sm" id="bank-search" placeholder="Tìm kiếm câu hỏi...">
        </div>
        <div class="d-flex gap-2 mb-3">
          <select class="form-select form-select-sm" id="bank-type">
            <option value="">Loại câu hỏi</option>
            <option>Reading</option><option>Listening</option><option>Grammar</option><option>Vocabulary</option>
          </select>
          <select class="form-select form-select-sm" id="bank-level">
            <option value="">Độ khó</option>
            <option>Dễ</option><option>Trung bình</option><option>Khó</option>
          </select>
        </div>
        <div id="bank-list" style="max-height:480px;overflow-y:auto;"></div>
        <div class="text-muted small mt-2" id="bank-count"></div>
      </div>
    </div>
  </div>

  <!-- RIGHT: Current exam -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <div>
          <h6 class="fw-bold mb-0">Đề thi hiện tại</h6>
          <small class="text-muted" id="exam-info">0 câu hỏi | 60 phút</small>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-danger btn-sm" id="btn-clear">
            <i class="fas fa-trash-alt me-1"></i>Xóa tất cả
          </button>
          <button class="btn btn-primary btn-sm" id="btn-save-exam">
            <i class="fas fa-save me-1"></i>Lưu đề thi
          </button>
        </div>
      </div>
      <div class="card-body d-flex flex-column" id="exam-drop-zone" style="min-height:480px;overflow-y:auto;">
        <div id="exam-empty" class="m-auto d-flex flex-column align-items-center justify-content-center text-muted py-5">
          <i class="fas fa-file-alt fa-3x mb-3 opacity-25"></i>
          <p class="mb-0">Kéo thả câu hỏi vào đây</p>
          <small>hoặc click nút + để thêm</small>
        </div>
        <div id="exam-list" class="d-flex flex-column mt-2"></div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
  // ===== Mock data =====
  const ALL_QUESTIONS = [
    { id: 1, text: 'According to the passage, what is the main purpose of the new policy?', type: 'Reading',    topic: 'TOEIC',      level: 'Trung bình' },
    { id: 2, text: 'What does the speaker suggest about urban planning?',                   type: 'Listening',  topic: 'IELTS',      level: 'Khó' },
    { id: 3, text: 'Choose the correct form: She _____ to the office every day.',          type: 'Grammar',    topic: 'Grammar',    level: 'Dễ' },
    { id: 4, text: "What is the synonym of 'abundant'?",                                   type: 'Vocabulary', topic: 'Vocabulary', level: 'Trung bình' },
    { id: 5, text: "Identify the error: 'The team have decided to postpone their meeting'", type: 'Grammar',   topic: 'Grammar',    level: 'Khó' },
    { id: 6, text: 'What is the main topic of the article?',                               type: 'Reading',    topic: 'TOEIC',      level: 'Dễ' },
    { id: 7, text: "Choose the word that best completes: 'The project was _____ success'", type: 'Vocabulary', topic: 'Vocabulary', level: 'Trung bình' },
    { id: 8, text: 'According to the recording, what time does the train depart?',         type: 'Listening',  topic: 'IELTS',      level: 'Trung bình' },
    { id: 9, text: 'Select the word that best describes someone who works at night.',       type: 'Vocabulary', topic: 'Vocabulary', level: 'Dễ' },
    { id: 10, text: 'The author implies that the economy will recover by next year.',       type: 'Reading',    topic: 'TOEIC',      level: 'Khó' },
  ];

  const TYPE_COLORS = {
    'Reading':    { bg: '#e8f4fd', color: '#1a73e8' },
    'Listening':  { bg: '#fce8f3', color: '#d63384' },
    'Grammar':    { bg: '#e8f5e9', color: '#2e7d32' },
    'Vocabulary': { bg: '#fff3e0', color: '#e65100' },
  };
  const LEVEL_COLORS = {
    'Dễ':         { bg: '#e8f5e9', color: '#2e7d32' },
    'Trung bình': { bg: '#fff8e1', color: '#f57f17' },
    'Khó':        { bg: '#fce4ec', color: '#c62828' },
  };

  let examQuestions = [];

  // ---- Helpers ----
  function typeIcon(type) {
    const icons = { Reading: '\uD83D\uDCD6', Listening: '\uD83C\uDFA7', Grammar: 'Aa', Vocabulary: 'Vv' };
    const c = TYPE_COLORS[type] || { color: '#555' };
    return '<span style="font-size:11px;font-weight:700;color:' + c.color + ';margin-right:2px;">' + (icons[type] || '?') + '</span>';
  }
  function topicBadge(topic) {
    return '<span style="display:inline-block;padding:1px 8px;border-radius:20px;border:1px solid #ccc;background:#f5f5f5;color:#444;font-size:10px;font-weight:500;">' + topic + '</span>';
  }
  function levelBadge(level) {
    var map = {
      'D\u1EC5':         { label: 'D\u1EC5',  bg: '#e8f5e9', color: '#2e7d32', border: '#a5d6a7' },
      'Trung b\u00ECnh': { label: 'TB',        bg: '#fff8e1', color: '#f57f17', border: '#ffe082' },
      'Kh\u00F3':        { label: 'Kh\u00F3',  bg: '#fce4ec', color: '#c62828', border: '#f48fb1' }
    };
    var c = map[level] || { label: level, bg: '#eee', color: '#555', border: '#ccc' };
    return '<span style="display:inline-block;padding:1px 8px;border-radius:20px;border:1px solid ' + c.border + ';background:' + c.bg + ';color:' + c.color + ';font-size:10px;font-weight:600;">' + c.label + '</span>';
  }
  function inExam(id) { return examQuestions.includes(id); }

  // ---- Render bank ----
  function getBankFiltered() {
    const s = document.getElementById('bank-search').value.toLowerCase();
    const t = document.getElementById('bank-type').value;
    const lv = document.getElementById('bank-level').value;
    return ALL_QUESTIONS.filter(q =>
      (!s  || q.text.toLowerCase().includes(s)) &&
      (!t  || q.type === t) &&
      (!lv || q.level === lv)
    );
  }

  function renderBank() {
    var list = document.getElementById('bank-list');
    var data = getBankFiltered();
    document.getElementById('bank-count').textContent = data.length + ' c\u00E2u h\u1ECFi c\u00F3 s\u1EB5n';
    if (!data.length) {
      list.innerHTML = '<div style="text-align:center;color:#aaa;padding:16px;font-size:13px;">Kh\u00F4ng t\u00ECm th\u1EA5y c\u00E2u h\u1ECFi</div>';
      return;
    }
    list.innerHTML = data.map(function(q) {
      var added = inExam(q.id);
      var badges = '<div style="display:flex;align-items:center;gap:5px;flex-wrap:wrap;margin-bottom:4px;">' + typeIcon(q.type) + topicBadge(q.topic) + levelBadge(q.level) + '</div>';
      var grip = '<i class="fas fa-grip-vertical" style="color:#ccc;font-size:11px;margin-top:3px;flex-shrink:0;"></i>';
      var textDiv = '<div style="font-size:12px;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:310px;" title="' + q.text + '">' + q.text + '</div>';
      var actionBtn = added
        ? '<span style="font-size:10px;background:#d4edda;color:#155724;padding:2px 8px;border-radius:20px;flex-shrink:0;margin-top:2px;">\u0110\u00E3 th\u00EAm</span>'
        : '<button onclick="event.stopPropagation();addToExam(' + q.id + ')" style="background:none;border:none;color:#0d6efd;font-size:20px;line-height:1;padding:0;cursor:pointer;flex-shrink:0;">+</button>';
      var bg = added ? '#f0f7ff' : '#fff';
      var cursor = added ? 'default' : 'pointer';
      var clickAttr = added ? '' : 'onclick="addToExam(' + q.id + ')"';
      return '<div ' + clickAttr + ' draggable="' + (!added) + '" ondragstart="dragStart(event,' + q.id + ')" style="display:flex;align-items:flex-start;gap:8px;padding:8px 10px;margin-bottom:6px;border:1px solid #e9ecef;border-radius:8px;background:' + bg + ';cursor:' + cursor + ';">' +
        grip + '<div style="flex:1;min-width:0;">' + badges + textDiv + '</div>' + actionBtn + '</div>';
    }).join('');
  }

  // ---- Render exam ----
  function updateExamInfo() {
    const dur = document.getElementById('exam-duration').value || 60;
    document.getElementById('exam-info').textContent = `${examQuestions.length} câu hỏi | ${dur} phút`;
  }

  function renderExam() {
    const empty = document.getElementById('exam-empty');
    const examList = document.getElementById('exam-list');
    updateExamInfo();

    if (!examQuestions.length) {
      empty.classList.remove('d-none');
      empty.classList.add('d-flex');
      examList.innerHTML = '';
      return;
    }
    empty.classList.remove('d-flex');
    empty.classList.add('d-none');

    examList.innerHTML = examQuestions.map(function(id) {
      var q = ALL_QUESTIONS.find(function(q) { return q.id === id; });
      var badges = '<div style="display:flex;align-items:center;gap:5px;flex-wrap:wrap;margin-bottom:4px;">' + typeIcon(q.type) + topicBadge(q.topic) + levelBadge(q.level) + '</div>';
      var textDiv = '<div style="font-size:12px;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:270px;" title="' + q.text + '">' + q.text + '</div>';
      return '<div style="display:flex;align-items:flex-start;gap:8px;padding:8px 10px;margin-bottom:6px;border:1px solid #e9ecef;border-radius:8px;background:#fff;">' +
        '<i class="fas fa-grip-vertical" style="color:#ccc;font-size:11px;margin-top:3px;cursor:grab;flex-shrink:0;"></i>' +
        '<div style="flex:1;min-width:0;">' + badges + textDiv + '</div>' +
        '<button onclick="removeFromExam(' + q.id + ')" style="background:none;border:none;color:#dc3545;cursor:pointer;padding:0;flex-shrink:0;margin-top:2px;" title="X\u00F3a"><i class="fas fa-times fa-sm"></i></button>' +
        '</div>';
    }).join('');
  }

  // ---- Actions ----
  window.addToExam = function(id) {
    if (!inExam(id)) {
      examQuestions.unshift(id); // xuất hiện ở trên cùng
      renderExam();
      renderBank();
    }
  };

  window.removeFromExam = function(id) {
    examQuestions = examQuestions.filter(i => i !== id);
    renderExam();
    renderBank();
  };

  // Drag & drop
  window.dragStart = function(e, id) { e.dataTransfer.setData('text/plain', id); };

  const dropZone = document.getElementById('exam-drop-zone');
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.outline = '2px dashed #0d6efd'; });
  dropZone.addEventListener('dragleave', () => { dropZone.style.outline = ''; });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.style.outline = '';
    const id = parseInt(e.dataTransfer.getData('text/plain'));
    addToExam(id);
  });

  document.getElementById('btn-clear').addEventListener('click', () => {
    if (!examQuestions.length) return;
    if (confirm('Xóa tất cả câu hỏi khỏi đề thi?')) {
      examQuestions = [];
      renderExam();
      renderBank();
    }
  });

  document.getElementById('btn-save-exam').addEventListener('click', () => {
    const name = document.getElementById('exam-name').value.trim();
    const duration = document.getElementById('exam-duration').value || 60;
    if (!name) { alert('Vui lòng nhập tên đề thi'); return; }
    if (!examQuestions.length) { alert('Vui lòng thêm ít nhất 1 câu hỏi'); return; }

    // Create a hidden form so browser will follow server redirect after POST
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/teacher/exams/store';

    const inputTitle = document.createElement('input');
    inputTitle.type = 'hidden';
    inputTitle.name = 'title';
    inputTitle.value = name;
    form.appendChild(inputTitle);

    const inputDuration = document.createElement('input');
    inputDuration.type = 'hidden';
    inputDuration.name = 'duration_minutes';
    inputDuration.value = duration;
    form.appendChild(inputDuration);

    // Append each question id as question_ids[]
    examQuestions.forEach(qid => {
      const qi = document.createElement('input');
      qi.type = 'hidden';
      qi.name = 'question_ids[]';
      qi.value = qid;
      form.appendChild(qi);
    });

    // Append form to body and submit
    document.body.appendChild(form);
    form.submit();
  });

  document.getElementById('exam-duration').addEventListener('input', updateExamInfo);

  ['bank-search','bank-type','bank-level'].forEach(id => {
    document.getElementById(id).addEventListener('input', renderBank);
    document.getElementById(id).addEventListener('change', renderBank);
  });

  // Init
  renderBank();
  renderExam();
})();
</script>
