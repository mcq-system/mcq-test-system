<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo đề thi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #38bdf8;
            --primary-hover: #0284c7;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --bg-body: #f9fafb;
            --bg-card: #ffffff;
            --bg-hover: #f3f4f6;

            /* Tags colors */
            --tag-de-bg: #dcfce7;
            --tag-de-text: #166534;
            --tag-tb-bg: #fef08a;
            --tag-tb-text: #854d0e;
            --tag-kho-bg: #fee2e2;
            --tag-kho-text: #991b1b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            padding: 24px;
            width: 100%;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Top Nav */
        .back-nav {
            font-size: 14px;
            color: var(--text-muted);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
        }

        .back-nav:hover {
            color: var(--text-main);
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 24px;
        }

        /* Settings Section */
        .exam-settings {
            display: flex;
            gap: 24px;
            align-items: flex-end;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group.flex-1 {
            flex: 1;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-main);
        }

        .input-control {
            padding: 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 14px;
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

        .input-control:focus {
            border-color: var(--primary-color);
        }

        .input-with-icon {
            position: relative;
        }

        .input-with-icon i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .input-with-icon input {
            padding-left: 36px;
        }

        /* Select Control Customization */
        select.input-control {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%236b7280%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.4-12.8z%22%2F%3E%3C%2Fsvg%3E");
            background-repeat: no-repeat;
            background-position: right 12px top 50%;
            background-size: 10px auto;
            padding-right: 32px;
            background-color: white;
        }

        /* Main Grid */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            align-items: start;
        }

        /* Column Headers */
        .col-header {
            margin-bottom: 20px;
        }

        .col-header h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .col-header p {
            font-size: 13px;
            color: var(--text-muted);
        }

        .col-header-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        /* Filters */
        .search-full {
            margin-bottom: 12px;
        }

        .filter-row {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
        }

        /* Question List */
        .question-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 500px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .question-item {
            display: flex;
            gap: 12px;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: var(--bg-card);
            cursor: grab;
            transition: border-color 0.2s, background 0.2s;
        }

        .question-item:hover {
            border-color: #cbd5e1;
            background: var(--bg-hover);
        }

        /* Hiệu ứng mờ đi khi đang nắm kéo */
        .question-item.dragging {
            opacity: 0.5;
            border: 2px dashed var(--primary-color);
            background: var(--bg-hover);
        }

        .drag-handle {
            color: #cbd5e1;
            cursor: grab;
            padding-top: 4px;
        }

        .q-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .q-tags {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 500;
        }

        .tag-type {
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .tag-diff {
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
        }

        .diff-de {
            background: var(--tag-de-bg);
            color: var(--tag-de-text);
        }

        .diff-tb {
            background: var(--tag-tb-bg);
            color: var(--tag-tb-text);
        }

        .diff-kho {
            background: var(--tag-kho-bg);
            color: var(--tag-kho-text);
        }

        .q-text {
            font-size: 14px;
            line-height: 1.5;
            color: var(--text-main);
        }

        .bottom-info {
            margin-top: 16px;
            font-size: 13px;
            color: var(--text-muted);
            text-align: left;
        }

        /* Right Column Buttons */
        .actions {
            display: flex;
            gap: 12px;
        }

        .btn {
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            transition: all 0.2s;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
        }

        .btn-outline:hover {
            color: var(--text-main);
            border-color: #9ca3af;
        }

        .btn-primary {
            background: var(--primary-color);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-hover);
        }

        /* Dropzone */
        .dropzone {
            border: 2px dashed var(--border-color);
            border-radius: 8px;
            min-height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-body);
            transition: border-color 0.2s;
        }

        .dropzone.drag-over {
            border-color: var(--primary-color);
            background: #f0f9ff;
        }

        .drop-content {
            text-align: center;
            color: var(--text-muted);
        }

        .drop-content i {
            font-size: 32px;
            margin-bottom: 12px;
            color: #cbd5e1;
        }

        .drop-content p {
            font-size: 14px;
            line-height: 1.5;
        }
    </style>
</head>

<body>

    <div class="container">
        <!-- Top Nav -->
        <div>
            <a href="#" class="back-nav"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
        </div>

        <!-- Exam Settings -->
        <div class="card exam-settings">
            <div class="form-group flex-1">
                <label>Tên đề thi</label>
                <input type="text" class="input-control" placeholder="VD: TOEIC Practice Test 1">
            </div>
            <div class="form-group" style="width: 200px;">
                <label>Thời gian (phút)</label>
                <div class="input-with-icon">
                    <i class="fa-regular fa-clock"></i>
                    <input type="number" class="input-control" value="60">
                </div>
            </div>
            <div class="form-group" style="width: 200px;">
                <label>Topic</label>
                <select class="input-control">
                    <option>Chọn topic</option>
                    <option>TOEIC</option>
                    <option>IELTS</option>
                </select>
            </div>
        </div>

        <!-- Main Workspace -->
        <div class="main-grid">

            <!-- Left Column: Question Bank -->
            <div class="card">
                <div class="col-header">
                    <h3>Ngân hàng câu hỏi</h3>
                    <p>Kéo thả hoặc click để thêm vào đề thi</p>
                </div>

                <div class="search-full input-with-icon">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" class="input-control" placeholder="Tìm kiếm câu hỏi...">
                </div>

                <div class="filter-row">
                    <select class="input-control flex-1">
                        <option>Tất cả loại</option>
                        <option>Ngữ pháp</option>
                        <option>Từ vựng</option>
                    </select>
                    <select class="input-control flex-1">
                        <option>Tất cả</option>
                        <option>Dễ</option>
                        <option>Trung bình</option>
                        <option>Khó</option>
                    </select>
                </div>

                <div class="question-list" id="questionBank">
                    <!-- Q1 -->
                    <div class="question-item" draggable="true">
                        <i class="fa-solid fa-grip-vertical drag-handle"></i>
                        <div class="q-content">
                            <div class="q-tags">
                                <span class="tag-type"><i class="fa-solid fa-table-cells"></i> TOEIC</span>
                                <span class="tag-diff diff-tb">TB</span>
                            </div>
                            <p class="q-text">According to the passage, what is the main purpose of the new policy?</p>
                        </div>
                    </div>
                    <!-- Q2 -->
                    <div class="question-item" draggable="true">
                        <i class="fa-solid fa-grip-vertical drag-handle"></i>
                        <div class="q-content">
                            <div class="q-tags">
                                <span class="tag-type"><i class="fa-solid fa-headphones"></i> IELTS</span>
                                <span class="tag-diff diff-kho">Khó</span>
                            </div>
                            <p class="q-text">What does the speaker suggest about urban planning?</p>
                        </div>
                    </div>
                    <!-- Q3 -->
                    <div class="question-item" draggable="true">
                        <i class="fa-solid fa-grip-vertical drag-handle"></i>
                        <div class="q-content">
                            <div class="q-tags">
                                <span class="tag-type"><i class="fa-solid fa-font"></i> Grammar</span>
                                <span class="tag-diff diff-de">Dễ</span>
                            </div>
                            <p class="q-text">Choose the correct form: She _____ to the office every day.</p>
                        </div>
                    </div>
                    <!-- Q4 -->
                    <div class="question-item" draggable="true">
                        <i class="fa-solid fa-grip-vertical drag-handle"></i>
                        <div class="q-content">
                            <div class="q-tags">
                                <span class="tag-type"><i class="fa-solid fa-spell-check"></i> Vocabulary</span>
                                <span class="tag-diff diff-tb">TB</span>
                            </div>
                            <p class="q-text">What is the synonym of "abundant"?</p>
                        </div>
                    </div>
                    <!-- Q5 -->
                    <div class="question-item" draggable="true">
                        <i class="fa-solid fa-grip-vertical drag-handle"></i>
                        <div class="q-content">
                            <div class="q-tags">
                                <span class="tag-type"><i class="fa-solid fa-font"></i> Grammar</span>
                                <span class="tag-diff diff-tb">TB</span>
                            </div>
                            <p class="q-text">Select the correct sentence structure.</p>
                        </div>
                    </div>
                </div>

                <div class="bottom-info">
                    10 câu hỏi có sẵn
                </div>
            </div>

            <!-- Right Column: Current Exam -->
            <div class="card">
                <div class="col-header col-header-flex">
                    <div>
                        <h3>Đề thi hiện tại</h3>
                        <p>0 câu hỏi | 0 phút</p>
                    </div>
                    <div class="actions">
                        <button class="btn btn-outline"><i class="fa-regular fa-trash-can"></i> Xóa tất cả</button>
                        <button class="btn btn-primary">Lưu đề thi</button>
                    </div>
                </div>

                <div class="dropzone" id="examDropzone">
                    <div class="drop-content">
                        <i class="fa-regular fa-file-lines"></i>
                        <p>Kéo thả câu hỏi vào đây<br>hoặc click nút để thêm</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- JS mô phỏng Drag & Drop -->
    <script>
        const draggables = document.querySelectorAll('.question-item');
        const dropzone = document.getElementById('examDropzone');
        const questionBank = document.getElementById('questionBank');
        const dropContent = dropzone.querySelector('.drop-content');

        // Khởi tạo style cho dropzone để hoạt động như một list
        dropzone.style.display = 'flex';
        dropzone.style.flexDirection = 'column';
        dropzone.style.gap = '8px';

        // Hàm kiểm tra và cập nhật giao diện của Dropzone
        function updateDropzoneState() {
            const items = dropzone.querySelectorAll('.question-item');
            if (items.length === 0) {
                dropContent.style.display = 'block';
                dropzone.style.padding = '0';
                dropzone.style.justifyContent = 'center';
                dropzone.style.alignItems = 'center';
            } else {
                dropContent.style.display = 'none';
                dropzone.style.padding = '16px';
                dropzone.style.justifyContent = 'flex-start';
                dropzone.style.alignItems = 'stretch';
            }
        }

        // Gắn sự kiện cho các item có thể kéo
        draggables.forEach(draggable => {
            draggable.addEventListener('dragstart', () => {
                draggable.classList.add('dragging');
            });

            draggable.addEventListener('dragend', () => {
                draggable.classList.remove('dragging');
                updateDropzoneState();
            });
        });

        const containers = [questionBank, dropzone];

        // Xử lý sự kiện kéo thả cho cả 2 cột
        containers.forEach(container => {
            container.addEventListener('dragover', e => {
                e.preventDefault();
                const dragging = document.querySelector('.dragging');
                if (!dragging) return;

                // Xử lý riêng UI cho vùng thả đề thi
                if (container === dropzone) {
                    container.classList.add('drag-over');
                    dropContent.style.display = 'none';
                    dropzone.style.padding = '16px';
                    dropzone.style.justifyContent = 'flex-start';
                    dropzone.style.alignItems = 'stretch';
                }

                // Tính toán vị trí thả để sắp xếp thứ tự
                const afterElement = getDragAfterElement(container, e.clientY);
                if (afterElement == null) {
                    container.appendChild(dragging);
                } else {
                    container.insertBefore(dragging, afterElement);
                }
            });

            container.addEventListener('dragleave', () => {
                if (container === dropzone) {
                    container.classList.remove('drag-over');
                }
            });

            container.addEventListener('drop', () => {
                if (container === dropzone) {
                    container.classList.remove('drag-over');
                }
            });
        });

        // Hàm tính toán element nằm ngay dưới vị trí chuột
        function getDragAfterElement(container, y) {
            const draggableElements = [...container.querySelectorAll('.question-item:not(.dragging)')];

            return draggableElements.reduce((closest, child) => {
                const box = child.getBoundingClientRect();
                // Lấy khoảng cách từ tâm element đến con trỏ chuột
                const offset = y - box.top - box.height / 2;

                if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                } else {
                    return closest;
                }
            }, { offset: Number.NEGATIVE_INFINITY }).element;
        }
    </script>
</body>

</html>