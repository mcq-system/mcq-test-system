<style>
    :root {
        --primary-color: #38bdf8;
        --primary-hover: #0284c7;
        --text-main: #111827;
        --text-muted: #6b7280;
        --border-color: #e5e7eb;
        --bg-body: #f9fafb;
        --bg-card: #ffffff;
        --bg-hover: #f3f4f6;

        /* Tags colors */
        --tag-de-bg: #dcfce7;
        --tag-de-text: #166534;
        --tag-tb-bg: #fef08a;
        --tag-tb-text: #854d0e;
        --tag-kho-bg: #fee2e2;
        --tag-kho-text: #991b1b;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        color: var(--text-main);
        padding: 24px;
        width: 100%;
        min-height: 100vh;
    }

    .container {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Top Nav */
    .back-nav {
        font-size: 14px;
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
    }

    .back-nav:hover {
        color: var(--text-main);
    }

    .card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 24px;
    }

    /* Settings Section */
    .exam-settings {
        display: flex;
        flex-direction: row;
        gap: 24px;
        align-items: flex-end;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group.flex-1 {
        flex: 1;
    }

    .form-group label {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-main);
    }

    .input-control {
        padding: 10px 12px;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        font-size: 14px;
        outline: none;
        width: 100%;
        transition: border-color 0.2s;
    }

    .input-control:focus {
        border-color: var(--primary-color);
    }

    .input-with-icon {
        position: relative;
    }

    .input-with-icon i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
    }

    .input-with-icon input {
        padding-left: 36px;
    }

    /* Select Control Customization */
    select.input-control {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%236b7280%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.4-12.8z%22%2F%3E%3C%2Fsvg%3E");
        background-repeat: no-repeat;
        background-position: right 12px top 50%;
        background-size: 10px auto;
        padding-right: 32px;
        background-color: white;
    }

    /* Main Grid */
    .main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
    }

    /* Column Headers */
    .col-header {
        margin-bottom: 20px;
    }

    .col-header h3 {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .col-header p {
        font-size: 13px;
        color: var(--text-muted);
    }

    .col-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    /* Filters */
    .search-full {
        margin-bottom: 12px;
    }

    .filter-row {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
    }

    /* Question List */
    .question-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        height: 500px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .question-item {
        display: flex;
        gap: 12px;
        padding: 12px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        background: var(--bg-card);
        cursor: grab;
        transition: border-color 0.2s, background 0.2s;
    }

    .question-item:hover {
        border-color: #cbd5e1;
        background: var(--bg-hover);
    }

    /* Hiệu ứng mờ đi khi đang nắm kéo */
    .question-item.dragging {
        opacity: 0.5;
        border: 2px dashed var(--primary-color);
        background: var(--bg-hover);
    }

    .drag-handle {
        color: #cbd5e1;
        cursor: grab;
        padding-top: 4px;
    }

    .btn-add-q {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        border-radius: 6px;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        align-self: center;
    }

    .btn-add-q:hover {
        border-color: var(--primary-color);
        color: var(--primary-color);
        background: #f0f9ff;
    }

    .q-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .q-tags {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 500;
    }

    .type-badge {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .type-reading {
        background: #e8f4fd;
        color: #1a73e8;
    }

    .type-listening {
        background: #fce8f3;
        color: #d63384;
    }

    .type-grammar {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .type-vocabulary {
        background: #fff3e0;
        color: #e65100;
    }

    .level-badge {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .level-de {
        border-color: #a5d6a7;
        background: #e8f5e9;
        color: #2e7d32;
    }

    .level-tb {
        border-color: #ffe082;
        background: #fff8e1;
        color: #f57f17;
    }

    .level-kho {
        border-color: #f48fb1;
        background: #fce4ec;
        color: #c62828;
    }

    .q-text {
        font-size: 14px;
        line-height: 1.5;
        color: var(--text-main);
    }

    .bottom-info {
        margin-top: 16px;
        font-size: 13px;
        color: var(--text-muted);
        text-align: left;
    }

    /* Right Column Buttons */
    .actions {
        display: flex;
        gap: 12px;
    }

    .btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: none;
        transition: all 0.2s;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
    }

    .btn-outline:hover {
        color: var(--text-main);
        border-color: #9ca3af;
    }

    .btn-primary {
        background: var(--primary-color);
        color: white;
    }

    .btn-primary:hover {
        background: var(--primary-hover);
    }

    /* Dropzone */
    .dropzone-container {
        height: 500px;
        overflow-y: auto;
        border: 2px dashed var(--border-color);
        border-radius: 8px;
        background: var(--bg-body);
        transition: border-color 0.2s;
        padding: 16px;
    }

    .dropzone {
        min-height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .dropzone-container.drag-over {
        border-color: var(--primary-color);
        background: #f0f9ff;
    }

    .drop-content {
        text-align: center;
        color: var(--text-muted);
    }

    .drop-content i {
        font-size: 32px;
        margin-bottom: 12px;
        color: #cbd5e1;
    }

    .drop-content p {
        font-size: 14px;
        line-height: 1.5;
    }
</style>
