<title>Chi tiết lớp học</title>
<style>
  .detail-container {
    animation: fadeIn 0.5s ease-out;
  }

  .class-header-card {
    background: #fff;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid #edf2f7;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .class-info h2 {
    margin: 0;
    font-size: 24px;
    color: #1e293b;
  }

  .class-info p {
    margin: 4px 0 0;
    color: #64748b;
  }

  .stats-row {
    display: flex;
    gap: 20px;
    margin-bottom: 24px;
  }

  .stat-mini-card {
    flex: 1;
    background: #fff;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid #edf2f7;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .stat-mini-icon {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .bg-blue { background: #eff6ff; color: #3b82f6; }
  .bg-green { background: #f0fdf4; color: #22c55e; }
  .bg-purple { background: #faf5ff; color: #a855f7; }

  .content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
  }

  .section-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #edf2f7;
    overflow: hidden;
  }

  .section-header {
    padding: 16px 20px;
    border-bottom: 1px solid #edf2f7;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .section-header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .member-list {
    width: 100%;
    border-collapse: collapse;
  }

  .member-list th {
    text-align: left;
    padding: 12px 20px;
    background: #f8fafc;
    font-size: 12px;
    text-transform: uppercase;
    color: #64748b;
    font-weight: 600;
  }

  .member-list td {
    padding: 15px 20px;
    border-bottom: 1px solid #edf2f7;
    font-size: 14px;
  }

  .student-avatar {
    width: 32px;
    height: 32px;
    background: #e2e8f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: #475569;
  }

  .btn-invite {
    background: #0070f3;
    color: #fff;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .exam-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px solid #edf2f7;
  }

  .exam-item:last-child { border-bottom: none; }

  .exam-info h4 {
    margin: 0;
    font-size: 14px;
    color: #1e293b;
  }

  .exam-info span {
    font-size: 12px;
    color: #64748b;
  }

  .status-badge {
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
  }

  .status-published { background: #dcfce7; color: #16a34a; }
  .status-draft { background: #fef9c3; color: #ca8a04; }
</style>

<div class="detail-container">
  <div class="class-header-card">
    <div class="class-info">
      <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge bg-primary">{{cls.class_code}}</span>
        <h2 class="mb-0">{{cls.name}}</h2>
      </div>
      <p class="mb-1 text-muted">
        <i class="far fa-calendar-alt me-1"></i> {{formatDate cls.starting_date}} - {{formatDate cls.ending_date}}
      </p>
      <div class="mb-1 text-muted">
        <i class="fas fa-clock me-1"></i> 
        {{#each cls.study_schedule}}
          <span>{{this.dayVi}} ({{#each this.slots}}{{this.start}}-{{this.end}}{{#unless @last}}, {{/unless}}{{/each}}){{#unless @last}}, {{/unless}}</span>
        {{/each}}
      </div>
      <p>{{cls.description}}</p>
    </div>
    <div class="header-actions">
      <a href="/teacher/my-classes/{{cls._id}}/edit" class="btn btn-outline-primary btn-sm me-2">
        <i class="fas fa-edit me-1"></i> Chỉnh sửa
      </a>
      <a href="/teacher/my-classes" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
      </a>
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-mini-card">
      <div class="stat-mini-icon bg-blue"><i class="fas fa-users"></i></div>
      <div>
        <div class="text-muted small">Sinh viên</div>
        <div class="fw-bold fs-5">{{members.length}}</div>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon bg-green"><i class="fas fa-file-alt"></i></div>
      <div>
        <div class="text-muted small">Bài thi</div>
        <div class="fw-bold fs-5">{{exams.length}}</div>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon bg-purple"><i class="fas fa-calendar-check"></i></div>
      <div>
        <div class="text-muted small">Tỉ lệ tham gia</div>
        <div class="fw-bold fs-5">85%</div>
      </div>
    </div>
  </div>

  <div class="content-grid">
    <div class="section-card">
      <div class="section-header">
        <h3>Danh sách sinh viên</h3>
        <button class="btn-invite"><i class="fas fa-user-plus"></i> Mời sinh viên</button>
      </div>
      <table class="member-list">
        <thead>
          <tr>
            <th>Sinh viên</th>
            <th>Email</th>
            <th>Ngày tham gia</th>
            <th class="text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {{#each members}}
          <tr>
            <td>
              <div class="d-flex align-items-center gap-3">
                <div class="student-avatar">{{slice student_id.first_name 0 1}}</div>
                <div class="fw-bold">{{student_id.first_name}} {{student_id.last_name}}</div>
              </div>
            </td>
            <td>{{student_id.email}}</td>
            <td class="text-muted small">{{formatDate joined_at}}</td>
            <td class="text-end">
              <button class="btn btn-sm text-danger"><i class="fas fa-user-minus"></i></button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="text-center py-4 text-muted">Chưa có sinh viên nào tham gia lớp này.</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="section-card">
      <div class="section-header">
        <h3>Bài thi gần đây</h3>
      </div>
      <div class="exam-list">
        {{#each exams}}
        <div class="exam-item">
          <div class="exam-info">
            <h4>{{title}}</h4>
            <span>{{formatDate created_at}}</span>
          </div>
          <span class="status-badge {{#if (eq status 'PUBLISHED')}}status-published{{else}}status-draft{{/if}}">
            {{status}}
          </span>
        </div>
        {{else}}
        <div class="p-4 text-center text-muted small">Chưa có bài thi nào.</div>
        {{/each}}
      </div>
    </div>
  </div>
</div>
