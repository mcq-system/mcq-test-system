<style>
    .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .page-header h2 { margin: 0; font-size: 20px; }
    .exam-info-card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,.07); display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
    .info-item label { font-size: 12px; color: #888; font-weight: 600; text-transform: uppercase; }
    .info-item p { margin: 4px 0 0; font-size: 15px; font-weight: 600; color: #333; }
    .sessions-table { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.07); overflow: hidden; }
    .sessions-table table { width: 100%; border-collapse: collapse; }
    .sessions-table th { background: #28a745; color: #fff; padding: 14px 16px; text-align: left; font-size: 13px; font-weight: 600; }
    .sessions-table td { padding: 13px 16px; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
    .sessions-table tr:last-child td { border-bottom: none; }
    .sessions-table tr:hover td { background: #f8fff8; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-submitted { background: #d4edda; color: #155724; }
    .badge-doing { background: #fff3cd; color: #856404; }
    .badge-expired { background: #f8d7da; color: #721c24; }
    .score-chip { font-size: 16px; font-weight: 700; color: #4e73df; }
    .btn-sm { padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; }
    .btn-green { background: #28a745; color: #fff; }
    .btn-green:hover { background: #218838; color: #fff; }
    .summary-stats { display: flex; gap: 20px; margin-bottom: 20px; }
    .stat-pill { background: #fff; border-radius: 10px; padding: 12px 20px; box-shadow: 0 2px 6px rgba(0,0,0,.07); text-align: center; }
    .stat-pill .val { font-size: 22px; font-weight: 700; color: #28a745; }
    .stat-pill .lbl { font-size: 12px; color: #888; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; color: #28a745; text-decoration: none; font-size: 14px; font-weight: 600; }
    .back-link:hover { text-decoration: underline; }
</style>

<div class="page-header">
    <a href="/teacher/exams" class="back-link"><i class="fas fa-arrow-left"></i> Quay lại</a>
    <h2><i class="fas fa-users"></i> Kết quả: {{exam.title}}</h2>
</div>

<div class="exam-info-card">
    <div class="info-item">
        <label>Thời gian làm bài</label>
        <p>{{exam.duration_minutes}} phút</p>
    </div>
    <div class="info-item">
        <label>Tổng câu hỏi</label>
        <p>{{total}}</p>
    </div>
    <div class="info-item">
        <label>Trạng thái</label>
        <p>{{exam.status}}</p>
    </div>
    <div class="info-item">
        <label>Số thí sinh đã nộp</label>
        <p>{{countSubmitted sessions}}</p>
    </div>
</div>

<div class="sessions-table">
    <table>
        <thead>
        <tr>
            <th>#</th>
            <th>Học sinh</th>
            <th>Email</th>
            <th>Bắt đầu</th>
            <th>Nộp lúc</th>
            <th>Trạng thái</th>
            <th>Điểm</th>
            <th>Chi tiết</th>
        </tr>
        </thead>
        <tbody>
        {{#each sessions}}
            <tr>
                <td>{{add @index 1}}</td>
                <td><strong>{{student_id.last_name}} {{student_id.first_name}}</strong></td>
                <td>{{student_id.email}}</td>
                <td>{{formatDate started_at}}</td>
                <td>{{#if submitted_at}}{{formatDate submitted_at}}{{else}}-{{/if}}</td>
                <td>
                    {{#if (eq status "SUBMITTED")}}
                        <span class="badge badge-submitted">Đã nộp</span>
                    {{else if (eq status "DOING")}}
                        <span class="badge badge-doing">Đang làm</span>
                    {{else}}
                        <span class="badge badge-expired">Hết hạn</span>
                    {{/if}}
                </td>
                <td>
                    {{#if score}}
                        <span class="score-chip">{{score}}/10</span>
                    {{else}}-{{/if}}
                </td>
                <td>
                    {{#if (eq status "SUBMITTED")}}
                        <a href="/teacher/exam-sessions/{{_id}}/result" class="btn-sm btn-green">
                            <i class="fas fa-eye"></i> Xem
                        </a>
                    {{else}}-{{/if}}
                </td>
            </tr>
        {{/each}}
        </tbody>
    </table>
</div>
