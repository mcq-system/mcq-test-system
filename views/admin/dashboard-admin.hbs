<div class="mb-4">
    <h4 class="fw-bold m-0">Dashboard Admin</h4>
    <p class="text-muted small">Tổng quan hệ thống quản lý trắc nghiệm</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted small fw-bold">TỔNG GIẢNG VIÊN</div>
                    <div class="display-6 fw-bold mt-2">{{teacherCount}}</div>
                    <div class="text-success small mt-2"><i class="fas fa-arrow-up"></i> +{{teacherCount}} tháng này</div>
                </div>
                <div class="bg-primary-light p-3 rounded-circle">
                    <i class="fas fa-chalkboard-teacher text-primary"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted small fw-bold">TỔNG SINH VIÊN</div>
                    <div class="display-6 fw-bold mt-2">{{studentCount}}</div>
                    <div class="text-success small mt-2"><i class="fas fa-arrow-up"></i> +{{studentCount}} tháng này</div>
                </div>
                <div class="bg-success-light p-3 rounded-circle">
                    <i class="fas fa-users text-success"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted small fw-bold">TỔNG ĐỀ THI</div>
                    <div class="display-6 fw-bold mt-2">{{examCount}}</div>
                    <div class="text-muted small mt-2">+{{examCount}} tháng này</div>
                </div>
                <div class="bg-warning-light p-3 rounded-circle">
                    <i class="fas fa-file-alt text-warning"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted small fw-bold">LƯỢT THI TRONG THÁNG</div>
                    <div class="display-6 fw-bold mt-2">{{sessionsThisMonth}}</div>
                    <div class="text-success small mt-2"><i class="fas fa-chart-line"></i> +{{sessionsThisMonth}} so với tháng trước</div>
                </div>
                <div class="bg-info-light p-3 rounded-circle">
                    <i class="fas fa-bolt text-info"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-4">Hoạt động gần đây</h5>
        <div class="timeline">
            {{#if activities}}
                {{#each activities}}
                    <div class="d-flex mb-4">
                        <div class="flex-shrink-0 {{iconClass}} mt-1"><i class="fas fa-circle fa-xs"></i></div>
                        <div class="ms-3 flex-grow-1 border-bottom pb-3">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">{{title}}</span>
                                <span class="text-muted small">{{timeText}}</span>
                            </div>
                            <p class="text-muted small m-0">{{description}}</p>
                        </div>
                    </div>
                {{/each}}
            {{else}}
                <p class="text-muted small mb-0">Chưa có hoạt động gần đây.</p>
            {{/if}}
        </div>
    </div>
</div>
