{{!-- 
  views/admin/dashboard-student-stats.hbs
  Nguồn: nhánh han-be (merge vào dev)
  Mô tả: Body content hiển thị thống kê lớp học / bài thi dạng student-view
  Sử dụng: {{> dashboard-student-stats}} trong layout-admin
--}}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4">
            <div class="text-muted small fw-bold">LỚP ĐANG HỌC</div>
            <div class="display-5 fw-bold mt-2">{{stats.activeClasses}}</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4">
            <div class="text-muted small fw-bold">BÀI THI ĐÃ LÀM</div>
            <div class="display-5 fw-bold text-success mt-2">{{stats.examsDone}}</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4">
            <div class="text-muted small fw-bold">ĐIỂM TRUNG BÌNH</div>
            <div class="display-5 fw-bold text-warning mt-2">{{stats.avgScore}}</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold m-0">Lớp học của tôi</h5>
        <button class="btn btn-sm btn-outline-primary">Xem tất cả</button>
    </div>
    {{#each courses}}
    <div class="course-item d-flex align-items-center p-3 border rounded shadow-sm mb-3">
        <div class="bg-primary-light p-3 rounded me-3">
            <i class="fas fa-language text-primary fs-4"></i>
        </div>
        <div class="flex-grow-1">
            <div class="fw-bold">{{name}}</div>
            <div class="text-muted small">GV: {{teacher}}</div>
            <div class="progress mt-2" style="height: 8px; width: 300px;">
                <div class="progress-bar" style="width: {{progress}}%;"></div>
            </div>
        </div>
        <div class="text-end">
            <div class="fw-bold text-primary fs-5">{{progress}}%</div>
        </div>
    </div>
    {{else}}
    <p class="text-muted">Chưa có lớp học nào.</p>
    {{/each}}
</div>
