<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - MCQ System</title>
  <!-- Boxicons -->
  <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
  <link rel="stylesheet" href="../shared/global.css">
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <i class='bx bx-brain'></i>
        <span>MCQ Admin</span>
      </div>
      <div class="sidebar-menu">
        <div class="menu-label">Hệ thống</div>
        <a href="#" class="menu-item active">
          <i class='bx bx-desktop'></i>
          <span>Bảng điều khiển</span>
        </a>
        <a href="#" class="menu-item">
          <i class='bx bx-buildings'></i>
          <span>Quản lý trường học</span>
        </a>
        <div class="menu-label">Người dùng</div>
        <a href="#" class="menu-item">
          <i class='bx bx-id-card'></i>
          <span>Danh sách Giáo viên</span>
        </a>
        <a href="#" class="menu-item">
          <i class='bx bx-user'></i>
          <span>Danh sách Học sinh</span>
        </a>
        <div class="menu-label">Cấu hình</div>
        <a href="#" class="menu-item">
          <i class='bx bx-data'></i>
          <span>Sao lưu dữ liệu</span>
        </a>
        <a href="#" class="menu-item">
          <i class='bx bx-cog'></i>
          <span>Cài đặt hệ thống</span>
        </a>
      </div>
      <div class="sidebar-settings">
        <a href="#" class="menu-item">
          <i class='bx bx-log-out'></i>
          <span>Đăng xuất</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
      <!-- Top Header -->
      <header class="top-header">
        <div class="search-bar">
          <i class='bx bx-search'></i>
          <input type="text" placeholder="Tìm kiếm mã người dùng, ID...">
        </div>
        <div class="header-actions">
          <button class="action-btn">
            <i class='bx bx-bug'></i>
          </button>
          <div class="user-profile">
            <div class="avatar" style="background-color: var(--danger);">AD</div>
            <div class="user-info">
              <span class="user-name">Root Admin</span>
              <span class="user-role">Quản trị viên</span>
            </div>
            <i class='bx bx-chevron-down' style="color: var(--text-muted);"></i>
          </div>
        </div>
      </header>

      <!-- Content -->
      <main class="content">
        <div class="page-header">
          <div>
            <h1 class="page-title">Trạng thái hệ thống</h1>
            <div class="breadcrumb">
              Tổng quan hoạt động và tài nguyên của toàn bộ hệ thống MCQ.
            </div>
          </div>
          <button class="btn btn-primary" style="background-color: var(--secondary);">
            <i class='bx bx-server'></i> Khởi động lại Server
          </button>
        </div>

        <!-- Stat Cards -->
        <div class="card-grid">
          <div class="stat-card">
            <div class="stat-info">
              <div class="stat-label">Tổng Giáo Viên</div>
              <div class="stat-value">45</div>
            </div>
            <div class="stat-icon icon-primary">
              <i class='bx bx-id-card'></i>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-info">
              <div class="stat-label">Tổng Học Sinh</div>
              <div class="stat-value">1,250</div>
            </div>
            <div class="stat-icon icon-info">
              <i class='bx bx-group'></i>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-info">
              <div class="stat-label">Số Đề Thi Đã Tạo</div>
              <div class="stat-value">320</div>
            </div>
            <div class="stat-icon icon-success">
              <i class='bx bx-file'></i>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-info">
              <div class="stat-label">Tải Hệ Thống (CPU)</div>
              <div class="stat-value">24%</div>
            </div>
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">
              <i class='bx bx-tachometer'></i>
            </div>
          </div>
        </div>

        <div class="grid-2">
          <!-- Users List Overview -->
          <div class="panel">
            <div class="panel-header">
              <h2 class="panel-title">Tài khoản truy cập gần đây</h2>
              <a href="#" style="font-size: 0.875rem; color: var(--info); font-weight: 500;">Tất cả users</a>
            </div>
            
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Họ Tên</th>
                    <th>Vai trò</th>
                    <th>Email</th>
                    <th>Đăng nhập cuối</th>
                    <th>Trạng thái</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Trần Thị B</td>
                    <td>Giáo viên</td>
                    <td>tranb@school.edu</td>
                    <td>2 phút trước</td>
                    <td><span class="status status-active">Online</span></td>
                  </tr>
                  <tr>
                    <td>Nguyễn Văn A</td>
                    <td>Học sinh</td>
                    <td>nva12@student.edu</td>
                    <td>15 phút trước</td>
                    <td><span class="status status-active">Online</span></td>
                  </tr>
                  <tr>
                    <td>Lê Quang C</td>
                    <td>Học sinh</td>
                    <td>lqc.2024@student.edu</td>
                    <td>Hôm qua</td>
                    <td><span class="status" style="background-color: var(--border-color); color: var(--text-muted);">Offline</span></td>
                  </tr>
                  <tr>
                    <td>Phạm Hùng D</td>
                    <td>Giáo viên</td>
                    <td>phd@school.edu</td>
                    <td>3 ngày trước</td>
                    <td><span class="status status-ended">Khóa</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- System Logs -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="panel">
              <div class="panel-header">
                <h2 class="panel-title">Cảnh báo hệ thống</h2>
                <i class='bx bx-dots-vertical-rounded'></i>
              </div>
              <div class="list-group">
                <div class="list-item">
                  <div class="item-icon icon-warning"><i class='bx bx-hdd'></i></div>
                  <div class="item-content">
                    <div class="item-title">Dung lượng Database</div>
                    <div class="item-desc">Đã sử dụng 85% dung lượng lưu trữ phân bổ.</div>
                    <div class="item-time">1 giờ trước</div>
                  </div>
                </div>
                <div class="list-item">
                  <div class="item-icon icon-danger"><i class='bx bx-shield-x'></i></div>
                  <div class="item-content">
                    <div class="item-title">Cố gắng truy cập trái phép</div>
                    <div class="item-desc">IP: 192.168.1.104 báo cáo sai mật khẩu quá 5 lần.</div>
                    <div class="item-time">4 giờ trước</div>
                  </div>
                </div>
                <div class="list-item">
                  <div class="item-icon icon-success"><i class='bx bx-check-shield'></i></div>
                  <div class="item-content">
                    <div class="item-title">Auto Backup thành công</div>
                    <div class="item-desc">Đã lưu trữ 2.4GB dữ liệu.</div>
                    <div class="item-time">Hôm qua, 00:00</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</body>
</html>
