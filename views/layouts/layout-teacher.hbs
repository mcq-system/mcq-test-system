<!DOCTYPE html>
<html>
<head>
    <title>{{title}}</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
<div class="app-container">
    <aside class="sidebar teacher-theme">
        <div class="sidebar-brand">
            <div class="logo-box" style="background: #28a745;"><i class="fas fa-chalkboard-teacher"></i></div>
            <div>
                <div style="font-weight: bold; font-size: 16px;">English MCQ</div>
                <div style="font-size: 12px; color: #888;">Giảng viên</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">TỔNG QUAN</div>
            <a href="/teacher/dashboard" class="nav-item active"><i class="fas fa-calendar-check"></i> Lịch dạy</a>
            <a href="/teacher/notifications" class="nav-item"><i class="fas fa-bell"></i> Thông báo</a>

            <div class="nav-section">QUẢN LÝ LỚP HỌC</div>
            <a href="/teacher/classes" class="nav-item"><i class="fas fa-users"></i> Lớp học của tôi</a>
            <a href="/teacher/classes/create" class="nav-item"><i class="fas fa-plus-circle"></i> Tạo lớp mới</a>

            <div class="nav-section">NGÂN HÀNG ĐỀ THI</div>
            <a href="/teacher/questions" class="nav-item"><i class="fas fa-database"></i> Câu hỏi</a>
            <a href="/teacher/exams/create" class="nav-item"><i class="fas fa-file-signature"></i> Tạo đề thi</a>
            <a href="/teacher/exams" class="nav-item"><i class="fas fa-list-ol"></i> Danh sách đề thi</a>
        </nav>


        <div class="sidebar-footer">
            <a href="/teacher/profile" class="user-card" style="text-decoration: none; color: inherit;">
                <div class="avatar-small">{{slice user.last_name 0 1}}</div>
                <div class="user-info-mini">
                    <div style="font-weight: 600; font-size: 14px;">
                        {{user.last_name}} {{user.first_name}}
                    </div>
                    <div style="font-size: 11px; color: #888;">
                        {{user.email}}
                    </div>
                </div>
            </a>
            <div class="footer-links">
                <a href="/logout" style="color: #dc3545; width: 100%; text-align: center;"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
            </div>
        </div>
    </aside>

    <main class="main-wrapper">
        <header class="main-header">
            <h2>{{title}}</h2>
            <div class="header-tools">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Tìm kiếm...">
                </div>
            </div>
        </header>
        <section class="main-content">{{{body}}}</section>
    </main>
</div>
</body>
</html>