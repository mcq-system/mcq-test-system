<!DOCTYPE html>
<html>

<head>
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
    <div class="app-container">
        <aside class="sidebar teacher-theme">
            <div class="sidebar-brand">
                <div class="logo-box" style="background: #28a745;"><i class="fas fa-chalkboard-teacher"></i></div>
                <div>
                    <div style="font-weight: bold; font-size: 16px;">English MCQ</div>
                    <div style="font-size: 12px; color: #888;">Giảng viên</div>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">TỔNG QUAN</div>
                <a href="/teacher/dashboard" class="nav-item active"><i class="fas fa-calendar-check"></i> <span>Lịch dạy</span></a>

                <div class="nav-section">QUẢN LÝ LỚP HỌC</div>
                <a href="/teacher/my-classes" class="nav-item"><i class="fas fa-users"></i> <span>Lớp học của tôi</span></a>
                <a href="/teacher/create-class" class="nav-item"><i class="fas fa-plus-circle"></i> <span>Tạo lớp mới</span></a>

                <div class="nav-section">NGÂN HÀNG ĐỀ THI</div>
                <a href="/teacher/questions" class="nav-item"><i class="fas fa-database"></i> <span>Câu hỏi</span></a>
                <a href="/teacher/create-exam" class="nav-item"><i class="fas fa-file-signature"></i> <span>Tạo đề thi</span></a>
                <a href="/teacher/exams" class="nav-item"><i class="fas fa-list-ol"></i> <span>Danh sách đề thi</span></a>
            </nav>


            <div class="sidebar-footer">
                <a href="/teacher/profile" class="user-card" style="text-decoration: none; color: inherit;">
                    <div class="avatar-small">{{slice user.last_name 0 1}}</div>
                    <div class="user-info-mini">
                        <div style="font-weight: 600; font-size: 14px;">
                            {{user.last_name}} {{user.first_name}}
                        </div>
                        <div style="font-size: 11px; color: #888;">
                            {{user.email}}
                        </div>
                    </div>
                </a>
                <div class="footer-links">
                    <a href="/teacher/profile"><i class="fas fa-cog"></i> <span>Cài đặt</span></a>
                    <a href="/auth/logout" style="color: #dc3545;"><i class="fas fa-sign-out-alt"></i> <span>Đăng xuất</span></a>
                </div>
            </div>
        </aside>

        <main class="main-wrapper">
            <header class="main-header">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <button id="toggle-sidebar" style="background: none; border: none; font-size: 20px; cursor: pointer; color: #555;">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h2 style="margin: 0;">{{title}}</h2>
                </div>
                <div class="header-tools">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Tìm kiếm...">
                    </div>
                    <a href="/teacher/notifications" class="noti-bell" style="text-decoration: none; position: relative;">
                        <i class="fas fa-bell"></i>
                        {{#if unreadNotificationsCount}}
                        <span style="position: absolute; top: -5px; right: -5px; background: #dc3545; color: white; border-radius: 50%; width: 15px; height: 15px; font-size: 10px; display: flex; align-items: center; justify-content: center; font-weight: bold;">{{unreadNotificationsCount}}</span>
                        {{/if}}
                    </a>
                </div>
            </header>
            <section class="main-content">{{{body}}}</section>
        </main>
    </div>
    <script src="/js/main.js"></script>
</body>

</html>